<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>2.7.0</version>
    </parent>

    <!-- Maven Coordinates -->
    <groupId>io.complyt</groupId>
    <artifactId>complyt</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <!-- Maven Coordinates -->

    <packaging>pom</packaging>
    <modules>
        <module>salesTax</module>
        <module>testService</module>
    </modules>

    <name>Complyt</name>
    <description>This is a product made by Complyt</description>

    <properties>
        <java.version>17</java.version>

        <!-- Plugins -->
        <maven-release-plugin.version>2.5.3</maven-release-plugin.version>
        <!-- Plugins -->
    </properties>

    <build>
        <plugins>
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>flatten-maven-plugin</artifactId>
                <version>1.3.0</version>
<!--                <configuration>-->
<!--                    <flattenMode>bom</flattenMode>-->
<!--                </configuration>-->
                <executions>
                    <!-- enable flattening -->
                    <execution>
                        <id>flatten</id>
                        <phase>process-resources</phase>
                        <goals>
                            <goal>flatten</goal>
                        </goals>
                    </execution>
                    <!-- ensure proper cleanup -->
                    <execution>
                        <id>flatten.clean</id>
                        <phase>clean</phase>
                        <goals>
                            <goal>clean</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-release-plugin</artifactId>
                <version>${maven-release-plugin.version}</version>
                <configuration>
                    <releaseProfiles>release</releaseProfiles>
                    <autoVersionSubmodules>true</autoVersionSubmodules>
                    <!-- [skip ci] tells the CI tools to ignore commits coming from the Maven Release Plugin -->
                    <scmCommentPrefix>[maven-release-plugin] [skip ci]</scmCommentPrefix>
                </configuration>
            </plugin>
        </plugins>
    </build>
    <scm>
        <connection>scm:git:git@github.com:Complyt/complyt.git</connection>
        <developerConnection>scm:git:git@github.com:Complyt/complyt.git</developerConnection>
        <url>git@github.com:idhub-io/idhub-api.git</url>
        <tag>HEAD</tag>
    </scm>

    <distributionManagement>
        <repository>
            <id>github</id>
            <name>GitHub Complyt Apache Maven Packages</name>
            <url>https://maven.pkg.github.com/Complyt/complyt</url>
        </repository>
    </distributionManagement>
</project>